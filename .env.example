# ─────────────────────────────────────────────────────────────
# Orbinest Client — Environment Variables
# Copy this file to .env and fill in the values before starting.
# All variables must be prefixed with VITE_ to be exposed to the browser.
# ─────────────────────────────────────────────────────────────

# Backend API base URL — no trailing slash
# Defaults to http://localhost:5000/api/v1 when omitted
VITE_API_URL=http://localhost:5000/api/v1
